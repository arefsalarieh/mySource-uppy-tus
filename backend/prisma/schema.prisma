generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  files    File[]
}

model File {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  extension    String
  size         Int
  path         String
  url          String
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
